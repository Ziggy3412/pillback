# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must include: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_at_least_32_chars

# ── Session ───────────────────────────────────────────────────────────────────
# Used only during the OAuth handshake – can be any random string
SESSION_SECRET=your_session_secret_here

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# URL of the web frontend – used for post-login redirect and CORS
CLIENT_URL=http://localhost:5173

# Public URL of this backend – used to build the absolute OAuth callbackURL
BACKEND_URL=http://localhost:3000
